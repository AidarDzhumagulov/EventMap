# Database
DB_HOST=db
DB_PORT=5432
DB_NAME=event_map
DB_USER=event_map
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Connection pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Security — сменить перед деплоем!
SALT=CHANGE_ME_RANDOM_SALT
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# Cloudflare R2 (Object Storage)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET=your_bucket_name
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-XXXX.r2.dev

# SMTP для писем (verification, password reset).
# Если не задан — письма пишутся в логи (NoopMailer).
# Resend: SMTP_USER=resend, SMTP_PASSWORD=<api_key>, SMTP_FROM=noreply@yourdomain.com
# Gmail:  SMTP_USER=your@gmail.com, SMTP_PASSWORD=<app_password>
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=CHANGE_ME_RESEND_API_KEY
SMTP_FROM=noreply@yourdomain.com

# URL приложения для ссылок в письмах.
# Dev: eventmap:// (deeplink в приложение)
# Prod: https://eventmap.example.com (universal link или web-fallback)
APP_URL=https://eventmap.example.com

# CORS для прода — список разрешённых origin'ов через запятую.
# Если не задан — режим dev (*) — НЕ ОСТАВЛЯТЬ В ПРОДЕ.
CORS_ORIGINS=https://yourapp.com
